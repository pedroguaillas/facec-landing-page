<section id="firmas" class="relative bg-white dark:bg-[#020b18] py-20 overflow-hidden">

  <!-- Blob light / glow dark -->
  <div class="pointer-events-none absolute -top-24 -left-24 w-96 h-96 bg-indigo-200 dark:bg-indigo-500 opacity-15 dark:opacity-5 rounded-full blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-24 -right-24 w-96 h-96 bg-sky-200 dark:bg-sky-500 opacity-15 dark:opacity-5 rounded-full blur-3xl"></div>

  <div class="container mx-auto flex flex-col text-center px-6 relative z-10">

    <!-- Badge -->
    <span class="reveal reveal-up inline-flex items-center gap-2 self-center bg-indigo-100 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 text-indigo-700 dark:text-indigo-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-widest">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path>
        <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path>
      </svg>
      Documentos necesarios
    </span>

    <!-- Title -->
    <h2 class="reveal reveal-up text-indigo-900 dark:text-white text-4xl lg:text-5xl font-extrabold mb-4">
      Requisitos para tu
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-sky-400 dark:from-indigo-400 dark:to-sky-300"> Firma Electrónica</span>
    </h2>

    <!-- Subtitle -->
    <p class="reveal reveal-up reveal-delay-1 text-indigo-700 dark:text-slate-400 text-lg lg:text-xl mb-4 max-w-2xl mx-auto">
      Somos <span class="font-semibold text-indigo-900 dark:text-white">distribuidores oficiales</span> de
      <span class="font-semibold text-indigo-800 dark:text-slate-200">UANATACA ECUADOR S.A.</span>, entidad certificada por <span class="font-semibold text-indigo-800 dark:text-slate-200">ARCOTEL</span>.
    </p>

    <!-- Trust badges -->
    <div class="reveal reveal-up reveal-delay-1 flex flex-wrap justify-center gap-3 mb-12">
      {[
        { icon: "⚡", label: "Proceso rápido" },
        { icon: "🔒", label: "100% seguro" },
        { icon: "✅", label: "Respaldo garantizado" },
        { icon: "📋", label: "Certificado ARCOTEL" },
      ].map((b) => (
        <span class="inline-flex items-center gap-1.5 bg-indigo-50 dark:bg-white/5 border border-indigo-200 dark:border-white/10 text-indigo-800 dark:text-slate-300 text-sm font-medium px-3 py-1.5 rounded-full">
          <span>{b.icon}</span>
          {b.label}
        </span>
      ))}
    </div>

    <!-- Cards -->
    <div class="flex flex-col lg:flex-row justify-between gap-8">

      <!-- Persona Natural -->
      <div class="reveal reveal-up reveal-delay-2 bg-white dark:bg-white/5 border border-indigo-100 dark:border-white/10 rounded-3xl w-full overflow-hidden shadow-md dark:shadow-none">
        <div class="bg-gradient-to-r from-indigo-600 to-indigo-500 p-6 text-white">
          <div class="w-14 h-14 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3">👤</div>
          <h3 class="text-2xl font-bold">Persona Natural</h3>
          <p class="text-indigo-200 text-sm mt-1">Documentos para titulares individuales</p>
          <div class="mt-3 inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">4 documentos</div>
        </div>
        <ol class="text-left p-6 space-y-3">
          {[
            { label: "Foto de la cédula anverso y reverso", icon: "🪪" },
            { label: "Foto Selfie enseñando la cédula", icon: "🤳" },
            { label: "Correo electrónico", icon: "📧" },
            { label: "Número celular activo para SMS", icon: "📱" },
          ].map((item, i) => (
            <li class="flex items-center gap-3 bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-100 dark:border-indigo-500/20 rounded-xl px-4 py-3">
              <span class="flex-shrink-0 w-7 h-7 bg-indigo-600 text-white rounded-full flex items-center justify-center text-xs font-bold">{i + 1}</span>
              <span class="text-lg leading-none">{item.icon}</span>
              <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">{item.label}</span>
            </li>
          ))}
        </ol>
      </div>

      <!-- Persona Juridica -->
      <div class="reveal reveal-up reveal-delay-3 bg-white dark:bg-white/5 border border-teal-100 dark:border-white/10 rounded-3xl w-full overflow-hidden shadow-md dark:shadow-none">
        <div class="bg-gradient-to-r from-teal-600 to-teal-500 p-6 text-white">
          <div class="w-14 h-14 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3">🏢</div>
          <h3 class="text-2xl font-bold">Persona Jurídica</h3>
          <p class="text-teal-100 text-sm mt-1">Documentos para empresas y organizaciones</p>
          <div class="mt-3 inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">7 documentos</div>
        </div>
        <ol class="text-left p-6 space-y-3">
          {[
            { label: "Foto de la cédula anverso y reverso", icon: "🪪" },
            { label: "Foto Selfie enseñando la cédula", icon: "🤳" },
            { label: "RUC actualizado en PDF", icon: "📄" },
            { label: "Correo electrónico", icon: "📧" },
            { label: "Número celular activo para SMS", icon: "📱" },
            { label: "Nombramiento vigente", icon: "📜" },
            { label: "Constitución o escritura de la empresa", icon: "🏛️" },
          ].map((item, i) => (
            <li class="flex items-center gap-3 bg-teal-50 dark:bg-teal-500/10 border border-teal-100 dark:border-teal-500/20 rounded-xl px-4 py-3">
              <span class="flex-shrink-0 w-7 h-7 bg-teal-600 text-white rounded-full flex items-center justify-center text-xs font-bold">{i + 1}</span>
              <span class="text-lg leading-none">{item.icon}</span>
              <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">{item.label}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- Bottom note -->
    <div class="reveal reveal-up reveal-delay-4 mt-10 flex items-center gap-3 bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 text-indigo-800 dark:text-slate-300 rounded-2xl px-6 py-4 max-w-2xl mx-auto text-sm text-left">
      <span class="text-2xl flex-shrink-0">💡</span>
      <p>
        <span class="font-semibold text-indigo-900 dark:text-white">¿Tienes dudas?</span> Nuestro equipo te guiará en cada paso. Contáctanos por WhatsApp y te asesoramos sin costo.
      </p>
    </div>
  </div>
</section>
