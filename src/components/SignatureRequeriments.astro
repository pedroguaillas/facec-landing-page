<section id="firmas" class="relative bg-gradient-to-br from-violet-50 via-white to-purple-50 py-20 overflow-hidden">

  <!-- Decorative blobs -->
  <div class="pointer-events-none absolute -top-24 -left-24 w-96 h-96 bg-violet-200 opacity-20 rounded-full blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-24 -right-24 w-96 h-96 bg-rose-200 opacity-20 rounded-full blur-3xl"></div>

  <div class="container mx-auto flex flex-col text-center px-6 relative z-10">

    <!-- Badge -->
    <span class="reveal reveal-up inline-flex items-center gap-2 self-center bg-rose-100 text-rose-600 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wide">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
      Documentos necesarios
    </span>

    <!-- Title -->
    <h2 class="reveal reveal-up text-violet-900 text-4xl lg:text-5xl font-extrabold mb-4">
      Requisitos para tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-rose-500">Firma Electrónica</span>
    </h2>

    <!-- Subtitle -->
    <p class="reveal reveal-up reveal-delay-1 text-purple-700 text-lg lg:text-xl mb-4 max-w-2xl mx-auto">
      Somos <span class="font-semibold text-violet-900">distribuidores oficiales</span> de
      <span class="font-semibold">UANATACA ECUADOR S.A.</span>, entidad certificada por <span class="font-semibold">ARCOTEL</span>.
    </p>

    <!-- Trust badges -->
    <div class="reveal reveal-up reveal-delay-1 flex flex-wrap justify-center gap-3 mb-12">
      {[
        { icon: "⚡", label: "Proceso rápido" },
        { icon: "🔒", label: "100% seguro" },
        { icon: "✅", label: "Respaldo garantizado" },
        { icon: "📋", label: "Certificado ARCOTEL" },
      ].map(b => (
        <span class="inline-flex items-center gap-1.5 bg-white border border-violet-100 text-violet-800 text-sm font-medium px-3 py-1.5 rounded-full shadow-sm">
          <span>{b.icon}</span>{b.label}
        </span>
      ))}
    </div>

    <!-- Cards -->
    <div class="flex flex-col lg:flex-row justify-between gap-8">

      <!-- Persona Natural -->
      <div class="reveal reveal-up reveal-delay-2 bg-white shadow-lg rounded-3xl w-full border border-violet-100 card-hover overflow-hidden">
        <!-- Card header -->
        <div class="bg-gradient-to-r from-violet-600 to-violet-500 p-6 text-white">
          <div class="w-14 h-14 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3">👤</div>
          <h3 class="text-2xl font-bold">Persona Natural</h3>
          <p class="text-violet-200 text-sm mt-1">Documentos para titulares individuales</p>
          <div class="mt-3 inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
            5 documentos
          </div>
        </div>
        <!-- Items -->
        <ol class="text-left p-6 space-y-3">
          {[
            { label: "Foto de la cédula anverso y reverso", icon: "🪪" },
            { label: "Selfie mostrando la cédula", icon: "🤳" },
            { label: "RUC actualizado en PDF (para facturar)", icon: "📄" },
            { label: "Correo electrónico válido", icon: "📧" },
            { label: "Número celular para código de verificación", icon: "📱" },
          ].map((item, i) => (
            <li class="flex items-center gap-3 bg-violet-50 rounded-xl px-4 py-3">
              <span class="flex-shrink-0 w-7 h-7 bg-violet-600 text-white rounded-full flex items-center justify-center text-xs font-bold">{i + 1}</span>
              <span class="text-lg leading-none">{item.icon}</span>
              <span class="text-gray-700 text-sm font-medium">{item.label}</span>
            </li>
          ))}
        </ol>
      </div>

      <!-- Persona Juridica -->
      <div class="reveal reveal-up reveal-delay-3 bg-white shadow-lg rounded-3xl w-full border border-rose-100 card-hover overflow-hidden">
        <!-- Card header -->
        <div class="bg-gradient-to-r from-rose-500 to-pink-500 p-6 text-white">
          <div class="w-14 h-14 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3">🏢</div>
          <h3 class="text-2xl font-bold">Persona Jurídica</h3>
          <p class="text-rose-100 text-sm mt-1">Documentos para empresas y organizaciones</p>
          <div class="mt-3 inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
            7 documentos
          </div>
        </div>
        <!-- Items -->
        <ol class="text-left p-6 space-y-3">
          {[
            { label: "Foto de la cédula anverso y reverso", icon: "🪪" },
            { label: "Selfie mostrando la cédula", icon: "🤳" },
            { label: "RUC actualizado en PDF", icon: "📄" },
            { label: "Correo electrónico válido", icon: "📧" },
            { label: "Número celular para código de verificación", icon: "📱" },
            { label: "Nombramiento vigente", icon: "📜" },
            { label: "Constitución o escritura de la empresa", icon: "🏛️" },
          ].map((item, i) => (
            <li class="flex items-center gap-3 bg-rose-50 rounded-xl px-4 py-3">
              <span class="flex-shrink-0 w-7 h-7 bg-rose-500 text-white rounded-full flex items-center justify-center text-xs font-bold">{i + 1}</span>
              <span class="text-lg leading-none">{item.icon}</span>
              <span class="text-gray-700 text-sm font-medium">{item.label}</span>
            </li>
          ))}
        </ol>
      </div>

    </div>

    <!-- Bottom note -->
    <div class="reveal reveal-up reveal-delay-4 mt-10 flex items-center gap-3 bg-amber-50 border border-amber-200 text-amber-800 rounded-2xl px-6 py-4 max-w-2xl mx-auto text-sm text-left">
      <span class="text-2xl flex-shrink-0">💡</span>
      <p><span class="font-semibold">¿Tienes dudas?</span> Nuestro equipo te guiará en cada paso. Contáctanos por WhatsApp y te asesoramos sin costo.</p>
    </div>

  </div>
</section>
