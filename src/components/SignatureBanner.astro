---
const features = [
  { icon: "🏛️", text: "Válida para SRI, facturación y trámites legales" },
  { icon: "⚡", text: "Entrega en minutos, sin complicaciones" },
  { icon: "💬", text: "Soporte personalizado por WhatsApp" },
  { icon: "🔒", text: "Certificada por ARCOTEL · UANATACA Ecuador" },
];
---

<!-- Light: gradiente indigo rico | Dark: navy profundo -->
<section class="relative overflow-hidden py-24 min-h-[92vh] flex items-center
  bg-gradient-to-br from-indigo-900 via-indigo-800 to-violet-900
  dark:bg-gradient-to-br dark:from-[#020b18] dark:via-[#020b18] dark:to-[#071527]">

  <!-- Glow orbs -->
  <div class="pointer-events-none absolute top-[-120px] left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full"
    style="background: radial-gradient(circle, rgba(99,102,241,0.22) 0%, rgba(79,70,229,0.10) 50%, transparent 70%);">
  </div>
  <div class="pointer-events-none absolute bottom-0 left-[-100px] w-[400px] h-[400px] rounded-full"
    style="background: radial-gradient(circle, rgba(14,165,233,0.18) 0%, transparent 70%);">
  </div>
  <div class="pointer-events-none absolute top-1/3 right-[-80px] w-[350px] h-[350px] rounded-full"
    style="background: radial-gradient(circle, rgba(139,92,246,0.16) 0%, transparent 70%);">
  </div>

  <!-- Grid lines -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.07]"
    style="background-image: linear-gradient(rgba(99,102,241,1) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,1) 1px, transparent 1px); background-size: 60px 60px;">
  </div>
  <div class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.35) 100%);">
  </div>

  <!-- Floating particles -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
  </div>

  <div class="container mx-auto px-6 xl:px-20 relative z-10">
    <div class="max-w-3xl mx-auto text-center">

      <!-- Badge -->
      <div class="reveal reveal-up inline-flex items-center gap-2 bg-white/10 border border-white/20 text-indigo-200 text-xs font-semibold px-4 py-1.5 rounded-full mb-6 uppercase tracking-widest backdrop-blur-sm">
        <span class="w-2 h-2 bg-indigo-300 rounded-full animate-pulse"></span>
        Certificado Digital Oficial · Ecuador
      </div>

      <!-- Headline -->
      <h1 class="reveal reveal-up reveal-delay-1 font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-tight mb-6">
        Tu Firma Electrónica<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 via-sky-200 to-indigo-300 animate-gradient">
          certificada y rápida
        </span>
      </h1>

      <!-- Price highlight -->
      <div class="reveal reveal-up reveal-delay-2 flex justify-center items-baseline gap-2 mb-4">
        <span class="text-indigo-300/70 text-xl">desde</span>
        <span class="text-6xl sm:text-7xl font-extrabold text-white">$7.77</span>
        <span class="text-indigo-300/70 text-xl">USD</span>
      </div>

      <!-- Subtext -->
      <p class="reveal reveal-up reveal-delay-3 text-indigo-200/80 text-lg lg:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
        Válida para el SRI, facturación electrónica y trámites legales en Ecuador. Recíbela en minutos, con soporte incluido.
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-up reveal-delay-4 flex flex-col sm:flex-row gap-4 justify-center mb-14">
        <a
          href="https://wa.me/593959649714"
          target="_blank"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-indigo-400 hover:bg-indigo-300 text-indigo-950 font-bold px-10 py-4 text-lg shadow-lg shadow-indigo-500/30 btn-hover transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Obtener mi firma ahora
        </a>
        <a
          href="#precios"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-white/10 hover:bg-white/20 text-white font-semibold px-10 py-4 text-lg border border-white/20 backdrop-blur-sm btn-hover transition-all"
        >
          Ver todos los precios
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>

      <!-- Feature pills -->
      <div class="reveal reveal-up reveal-delay-5 grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-2xl mx-auto mb-12">
        {features.map(f => (
          <div class="flex items-center gap-3 bg-white/8 border border-white/15 backdrop-blur-sm rounded-2xl px-5 py-3 text-left hover:bg-white/15 transition-colors">
            <span class="text-xl flex-shrink-0">{f.icon}</span>
            <span class="text-indigo-100 text-sm font-medium">{f.text}</span>
          </div>
        ))}
      </div>

      <!-- Trust -->
      <div class="reveal reveal-up reveal-delay-6 flex flex-wrap justify-center gap-6 text-sm text-indigo-300/70 font-medium">
        <span class="flex items-center gap-1.5"><span class="text-emerald-400">✅</span> Autorizado por el SRI</span>
        <span class="flex items-center gap-1.5"><span class="text-indigo-300">🔒</span> 100% seguro</span>
        <span class="flex items-center gap-1.5"><span class="text-sky-300">⚡</span> Entrega en minutos</span>
      </div>

    </div>
  </div>

  <!-- Bottom fade: empalma con SignaturePrices (indigo-50 en light, #071527 en dark) -->
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-32
    [background:linear-gradient(to_bottom,transparent,#eef2ff)]
    dark:[background:linear-gradient(to_bottom,transparent,#071527)]">
  </div>
</section>

<style>
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient {
    background-size: 200% auto;
    animation: gradient-shift 4s ease infinite;
  }

  .particle {
    position: absolute;
    border-radius: 9999px;
    background: rgba(99, 102, 241, 0.6);
    animation: float linear infinite;
  }
  .particle-1 { width: 3px; height: 3px; left: 15%; top: 20%; animation-duration: 8s; animation-delay: 0s; }
  .particle-2 { width: 2px; height: 2px; left: 75%; top: 35%; animation-duration: 12s; animation-delay: 2s; background: rgba(14,165,233,0.7); }
  .particle-3 { width: 4px; height: 4px; left: 55%; top: 70%; animation-duration: 10s; animation-delay: 4s; }
  .particle-4 { width: 2px; height: 2px; left: 30%; top: 60%; animation-duration: 14s; animation-delay: 1s; background: rgba(139,92,246,0.8); }
  .particle-5 { width: 3px; height: 3px; left: 85%; top: 15%; animation-duration: 9s; animation-delay: 3s; background: rgba(99,102,241,0.6); }

  @keyframes float {
    0%   { transform: translateY(0px) translateX(0px); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { transform: translateY(-120px) translateX(30px); opacity: 0; }
  }
</style>
