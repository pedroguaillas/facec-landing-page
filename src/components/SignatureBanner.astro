---
import { getCurrentPromotion, getDaysRemaining } from "../data/sign-prices.js";

const promo = getCurrentPromotion();
const days = promo ? getDaysRemaining(promo) : 0;
const starterPricing = promo?.pricings[0];
---

<section class="relative overflow-hidden bg-gradient-to-br from-violet-700 via-purple-700 to-rose-600 text-white py-20 px-4">
  <!-- Decoración de fondo -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute -top-16 -left-16 w-80 h-80 rounded-full bg-white"></div>
    <div class="absolute -bottom-20 -right-20 w-[28rem] h-[28rem] rounded-full bg-white"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full bg-white opacity-50"></div>
  </div>

  <div class="relative container mx-auto max-w-4xl text-center">

    <!-- Badge -->
    <div class="reveal reveal-up inline-flex items-center gap-2 bg-white/20 border border-white/30 text-white text-sm font-bold px-4 py-2 rounded-full mb-6 backdrop-blur-sm">
      <span>♀</span>
      {promo
        ? <span>{promo.display.badge} · {promo.display.title}</span>
        : <span>Certificado Digital Oficial · Ecuador</span>
      }
    </div>

    <!-- Título -->
    <h1 class="reveal reveal-up reveal-delay-1 text-5xl sm:text-6xl lg:text-7xl font-extrabold mb-4 leading-tight">
      Firma Electrónica
      <br />
      <span class="text-rose-300">certificada y rápida</span>
    </h1>

    <!-- Subtítulo -->
    <p class="reveal reveal-up reveal-delay-2 text-xl text-purple-100 mb-8 max-w-2xl mx-auto">
      {promo
        ? promo.display.subtitle + ". Oferta exclusiva por el Mes de la Mujer."
        : "Válida para el SRI, facturación electrónica y trámites legales. Recíbela en minutos."
      }
    </p>

    <!-- Precio estrella (solo si hay promo) -->
    {promo && starterPricing && (
      <div class="reveal reveal-up reveal-delay-3 flex justify-center items-end gap-6 mb-6">
        <div class="text-center">
          <p class="text-purple-200 text-sm mb-1">Precio normal</p>
          <p class="text-3xl font-bold line-through text-purple-300">${starterPricing.normalPrice.toFixed(2)}</p>
        </div>
        <div class="text-center">
          <p class="text-rose-200 text-sm mb-1">Precio promo</p>
          <p class="text-6xl font-extrabold">${starterPricing.promoPrice.toFixed(2)}</p>
          <p class="text-purple-200 text-xs mt-1">{starterPricing.quantity} años de vigencia</p>
        </div>
      </div>
    )}

    <!-- Highlight -->
    {promo && (
      <p class="reveal reveal-up reveal-delay-4 text-rose-200 font-semibold text-lg mb-6">
        {promo.display.highlight}
      </p>
    )}

    <!-- CTAs -->
    <div class="reveal reveal-up reveal-delay-5 flex flex-col sm:flex-row justify-center gap-4 mb-10">
      <a
        href="https://wa.me/593959649714"
        target="_blank"
        class="inline-flex items-center justify-center gap-2 bg-white text-violet-700 font-bold px-8 py-4 rounded-full shadow-lg hover:bg-rose-50 btn-hover text-lg"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Obtener mi firma ahora
      </a>
      <a
        href="#precios"
        class="inline-flex items-center justify-center gap-1 border-2 border-white/50 text-white hover:bg-white/10 px-8 py-4 rounded-full font-semibold btn-hover text-lg backdrop-blur-sm"
      >
        Ver todos los precios →
      </a>
    </div>

    <!-- Countdown (solo si hay promo) -->
    {promo && (
      <div class="reveal reveal-up reveal-delay-6">
        <p class="text-purple-200 text-sm mb-3">{promo.display.urgency}</p>
        <div id="countdown" class="flex justify-center gap-3 text-center">
          <div class="bg-white/15 backdrop-blur-sm rounded-2xl px-5 py-3 min-w-[72px] border border-white/20">
            <span id="cd-days" class="text-3xl font-extrabold block">--</span>
            <span class="text-xs text-purple-200 uppercase tracking-widest">Días</span>
          </div>
          <div class="bg-white/15 backdrop-blur-sm rounded-2xl px-5 py-3 min-w-[72px] border border-white/20">
            <span id="cd-hours" class="text-3xl font-extrabold block">--</span>
            <span class="text-xs text-purple-200 uppercase tracking-widest">Horas</span>
          </div>
          <div class="bg-white/15 backdrop-blur-sm rounded-2xl px-5 py-3 min-w-[72px] border border-white/20">
            <span id="cd-mins" class="text-3xl font-extrabold block">--</span>
            <span class="text-xs text-purple-200 uppercase tracking-widest">Minutos</span>
          </div>
          <div class="bg-white/15 backdrop-blur-sm rounded-2xl px-5 py-3 min-w-[72px] border border-white/20">
            <span id="cd-secs" class="text-3xl font-extrabold block">--</span>
            <span class="text-xs text-purple-200 uppercase tracking-widest">Segundos</span>
          </div>
        </div>
      </div>
    )}

    <!-- Stats (solo si NO hay promo) -->
    {!promo && (
      <div class="reveal reveal-up reveal-delay-4 flex justify-center gap-8 flex-wrap text-center">
        <div>
          <p class="text-3xl font-extrabold">5 min</p>
          <p class="text-purple-200 text-sm">Entrega promedio</p>
        </div>
        <div class="border-l border-white/20"></div>
        <div>
          <p class="text-3xl font-extrabold">100%</p>
          <p class="text-purple-200 text-sm">Válida SRI & MINTEL</p>
        </div>
        <div class="border-l border-white/20"></div>
        <div>
          <p class="text-3xl font-extrabold">24/7</p>
          <p class="text-purple-200 text-sm">Soporte incluido</p>
        </div>
      </div>
    )}
  </div>
</section>

{promo && (
  <script define:vars={{ endDate: promo.period.endDate }}>
    const end = new Date(endDate + "T23:59:59");

    function updateCountdown() {
      const diff = end - new Date();
      if (diff <= 0) {
        document.getElementById("countdown").innerHTML =
          '<p class="text-rose-300 font-semibold">Esta promoción ha finalizado.</p>';
        return;
      }
      const pad = (n) => String(Math.floor(n)).padStart(2, "0");
      document.getElementById("cd-days").textContent  = pad(diff / 864e5);
      document.getElementById("cd-hours").textContent = pad((diff % 864e5) / 36e5);
      document.getElementById("cd-mins").textContent  = pad((diff % 36e5) / 6e4);
      document.getElementById("cd-secs").textContent  = pad((diff % 6e4) / 1e3);
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  </script>
)}
