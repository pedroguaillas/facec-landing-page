---
const faqs = [
  {
    q: "¿La firma es válida para el SRI?",
    a: "Sí, todas nuestras firmas electrónicas cumplen con los requisitos del Servicio de Rentas Internas (SRI) y demás instituciones públicas.",
  },
  {
    q: "¿Puedo usar la firma para facturar?",
    a: "Claro. La firma en formato .p12 es compatible con cualquier sistema de facturación electrónica autorizado por el SRI.",
  },
  {
    q: "¿En cuánto tiempo recibiré mi firma?",
    a: "En promedio, entregamos tu certificado en 5 a 25 minutos después de recibir los requisitos y el pago.",
  },
];
---

<section id="faq" class="relative bg-white dark:bg-[#020b18] py-16 px-4 overflow-hidden">

  <!-- Glow/blob -->
  <div class="pointer-events-none absolute top-0 right-0 w-[350px] h-[350px] rounded-full"
    style="background: radial-gradient(circle, rgba(99,102,241,0.06) 0%, transparent 70%);">
  </div>

  <div class="container mx-auto max-w-3xl relative z-10">

    <!-- Title -->
    <div class="reveal reveal-up text-center mb-12">
      <span class="inline-flex items-center gap-2 bg-indigo-100 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 text-indigo-700 dark:text-indigo-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-widest">
        Resolvemos tus dudas
      </span>
      <h2 class="text-3xl font-extrabold text-indigo-900 dark:text-white md:text-4xl">
        Preguntas frecuentes
      </h2>
    </div>

    <div class="divide-y divide-indigo-100 dark:divide-white/10">
      {faqs.map((faq, i) => (
        <div class={`reveal reveal-up reveal-delay-${i + 1} py-7 first:pt-0`}>
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-indigo-100 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 rounded-full flex items-center justify-center">
              <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                <path d="M12 17h.01"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-indigo-900 dark:text-white mb-1">{faq.q}</h3>
              <p class="text-indigo-700 dark:text-slate-400">{faq.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
