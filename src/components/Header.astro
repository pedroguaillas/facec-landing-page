<header class="sticky top-0 z-50 w-full bg-white/90 dark:bg-[#020b18]/90 backdrop-blur-md border-b border-sky-100 dark:border-white/8 shadow-sm dark:shadow-none">
  <div class="container mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-8 h-8 bg-gradient-to-br from-sky-400 to-sky-700 rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-sky-300 transition-shadow">
        <span class="text-white font-extrabold text-sm">F</span>
      </div>
      <span class="bg-gradient-to-r from-sky-500 to-sky-900 bg-clip-text text-transparent font-extrabold text-2xl tracking-tight">
        facec
      </span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden sm:flex items-center gap-1">
      <a href="#precios" class="px-3 py-2 rounded-lg text-sm text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">Precios</a>
      <a href="#caracteristicas" class="px-3 py-2 rounded-lg text-sm text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">Características</a>
      <a href="/firma-electronica" class="px-3 py-2 rounded-lg text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-500/10 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors">
        Firmas
      </a>
      <a href="#faq" class="px-3 py-2 rounded-lg text-sm text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">FAQ</a>
      <a href="#contactame" class="px-3 py-2 rounded-lg text-sm text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">Contáctanos</a>
    </nav>

    <!-- CTA desktop + mobile toggle -->
    <div class="flex items-center gap-2">

      <!-- Theme toggle button -->
      <button
        id="theme-toggle"
        aria-label="Cambiar tema"
        class="p-2 rounded-lg text-sky-600 dark:text-slate-300 hover:bg-sky-50 dark:hover:bg-white/8 transition-colors"
      >
        <!-- Luna: visible en light mode -->
        <svg id="icon-moon" class="block dark:hidden w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
        <!-- Sol: visible en dark mode -->
        <svg id="icon-sun" class="hidden dark:block w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
      </button>

      <a
        href="https://app.facec.ec"
        target="_blank"
        aria-label="Ir al inicio de sesión de la aplicación FACEC"
        class="hidden sm:inline-flex items-center gap-2 bg-sky-600 hover:bg-sky-700 text-white text-sm font-semibold px-5 py-2 rounded-full shadow-md shadow-sky-200/50 dark:shadow-sky-900/30 btn-hover transition-all"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Iniciar sesión
      </a>

      <!-- Mobile menu button -->
      <button id="menu-toggle" class="sm:hidden p-2 rounded-lg bg-sky-600 text-white" aria-label="Abrir menu">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Overlay -->
<div id="menu-overlay" class="fixed inset-0 bg-black/30 backdrop-blur-sm hidden z-40 transition-opacity duration-300"></div>

<!-- Mobile sidebar -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 h-full w-72 bg-white dark:bg-[#020b18] shadow-2xl dark:shadow-black/50 transform translate-x-full transition-transform duration-300 sm:hidden flex flex-col z-50"
>
  <!-- Sidebar header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-sky-100 dark:border-white/10">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 bg-gradient-to-br from-sky-400 to-sky-700 rounded-lg flex items-center justify-center">
        <span class="text-white font-extrabold text-xs">F</span>
      </div>
      <span class="bg-gradient-to-r from-sky-500 to-sky-900 bg-clip-text text-transparent font-extrabold text-xl">facec</span>
    </div>
    <button id="close-menu" class="p-2 rounded-lg text-sky-600 dark:text-slate-300 hover:bg-sky-50 dark:hover:bg-white/8 transition-colors" aria-label="Cerrar menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Sidebar nav -->
  <nav class="flex flex-col px-4 py-4 gap-1 flex-1">
    <a href="#precios" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">
      <span class="text-base">💰</span> Precios
    </a>
    <a href="#caracteristicas" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">
      <span class="text-base">⚡</span> Características
    </a>
    <a href="/firma-electronica" class="flex items-center gap-3 px-4 py-3 rounded-xl text-indigo-600 dark:text-indigo-400 font-semibold hover:bg-indigo-50 dark:hover:bg-indigo-500/10 transition-colors">
      <span class="text-base">✍️</span>
      Firmas
    </a>
    <a href="#faq" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">
      <span class="text-base">❓</span> FAQ
    </a>
    <a href="#contactame" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sky-700 dark:text-slate-300 font-medium hover:bg-sky-50 dark:hover:bg-white/8 hover:text-sky-900 dark:hover:text-white transition-colors">
      <span class="text-base">💬</span> Contáctanos
    </a>
  </nav>

  <!-- Sidebar CTA -->
  <div class="px-4 pb-6">
    <a
      href="https://app.facec.ec"
      target="_blank"
      class="flex items-center justify-center gap-2 w-full bg-sky-600 hover:bg-sky-700 text-white font-semibold py-3 rounded-2xl shadow-md transition-all"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      Iniciar sesión
    </a>
  </div>
</div>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const closeMenu = document.getElementById("close-menu");
  const menuOverlay = document.getElementById("menu-overlay");

  function openMenu() {
    mobileMenu.classList.remove("translate-x-full");
    menuOverlay.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeMenuFn() {
    mobileMenu.classList.add("translate-x-full");
    menuOverlay.classList.add("hidden");
    document.body.style.overflow = "";
  }

  menuToggle.addEventListener("click", openMenu);
  closeMenu.addEventListener("click", closeMenuFn);
  menuOverlay.addEventListener("click", closeMenuFn);

  mobileMenu.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", closeMenuFn);
  });

  // Theme toggle
  document.getElementById("theme-toggle").addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
