---
const plans = [
    { label: "7 días", price: 7.77, desc: "Certificado válido por una semana.", highlight: false },
    { label: "30 días", price: 9.99, desc: "Certificado válido por 1 mes.", highlight: false },
    { label: "1 año", price: 17.91, desc: "Certificado válido por un año.", highlight: false },
    { label: "2 años", price: 27.85, desc: "Certificado válido por dos años.", highlight: true },
    { label: "3 años", price: 36.81, desc: "Certificado válido por tres años.", highlight: false },
    { label: "4 años", price: 45.76, desc: "Certificado válido por cuatro años.", highlight: false },
    { label: "5 años", price: 53.72, desc: "Certificado válido por cinco años.", highlight: false },
];
---

<section id="precios" class="relative bg-indigo-50/50 dark:bg-[#071527] py-20 px-4 overflow-hidden">
    <!-- Glow/blob -->
    <div
        class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full"
        style="background: radial-gradient(ellipse, rgba(99,102,241,0.08) 0%, transparent 70%);"
    >
    </div>

    <div class="container mx-auto max-w-5xl relative z-10">
        <!-- Header -->
        <div class="text-center mb-12">
            <span
                class="reveal reveal-up inline-flex items-center gap-2 bg-indigo-100 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 text-indigo-700 dark:text-indigo-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-widest"
            >
                <span class="w-2 h-2 bg-indigo-400 rounded-full"></span>
                Planes disponibles
            </span>
            <h2
                class="reveal reveal-up reveal-delay-1 text-3xl sm:text-4xl font-extrabold text-indigo-900 dark:text-white mb-3"
            >
                Precios de la Firma Electrónica
            </h2>
            <p class="reveal reveal-up reveal-delay-2 text-indigo-700 dark:text-slate-400 max-w-xl mx-auto">
                Elige la duración que más se ajuste a tus necesidades. Todos los certificados se entregan en formato <span
                    class="font-medium text-indigo-900 dark:text-slate-300">.p12</span
                >, compatibles con los sistemas autorizados por el SRI.
            </p>
        </div>

        <!-- Plans grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {
                plans.map((plan, i) => (
                    <div
                        class={`reveal reveal-up reveal-delay-${(i % 4) + 1} relative rounded-2xl border p-6 flex flex-col justify-between transition-all ${
                            plan.highlight
                                ? "bg-indigo-600/20 dark:bg-indigo-600/20 border-indigo-400 dark:border-indigo-500/50 shadow-lg shadow-indigo-200/50 dark:shadow-indigo-500/10"
                                : "bg-white dark:bg-white/5 border-indigo-100 dark:border-white/10 hover:border-indigo-200 dark:hover:border-white/20 shadow-sm dark:shadow-none"
                        }`}
                    >
                        {plan.highlight && (
                            <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-indigo-600 text-white text-xs font-bold px-3 py-1 rounded-full whitespace-nowrap">
                                Más popular
                            </span>
                        )}

                        <div>
                            <h3
                                class={`text-lg font-semibold mb-3 ${plan.highlight ? "text-indigo-700 dark:text-indigo-300" : "text-indigo-800 dark:text-slate-300"}`}
                            >
                                {plan.label}
                            </h3>
                            <p
                                class={`text-4xl font-extrabold mb-1 ${plan.highlight ? "text-indigo-900 dark:text-white" : "text-indigo-900 dark:text-white"}`}
                            >
                                ${plan.price.toFixed(2)}
                            </p>
                            <p class="text-slate-500 text-xs mb-5">{plan.desc}</p>
                        </div>

                        <a
                            href="https://wa.me/593959649714"
                            target="_blank"
                            class={`inline-flex items-center justify-center gap-2 rounded-full py-2.5 px-4 text-sm font-semibold btn-hover transition-all ${
                                plan.highlight
                                    ? "bg-indigo-600 hover:bg-indigo-500 text-white shadow-sm"
                                    : "bg-indigo-50 dark:bg-white/10 hover:bg-indigo-100 dark:hover:bg-white/20 text-indigo-700 dark:text-white border border-indigo-200 dark:border-white/10"
                            }`}
                        >
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                            </svg>
                            Contratar
                        </a>
                    </div>
                ))
            }
        </div>

        <p class="reveal reveal-up text-center text-xs text-indigo-400 dark:text-slate-600 mt-8">
            Todos los precios en USD · Formato .p12 · Válidos para facturación SRI y trámites legales
        </p>
    </div>
</section>
