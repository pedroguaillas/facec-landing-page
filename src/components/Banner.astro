---
const features = [
  { icon: "🧾", text: "Facturas, retenciones, notas de crédito y más" },
  { icon: "☁️", text: "100% en la nube, sin instalaciones" },
  { icon: "📱", text: "Funciona en cualquier dispositivo" },
  { icon: "⚡", text: "Emisión en bloque con un clic" },
];
---

<!-- Light: gradiente sky rico | Dark: navy profundo -->
<section class="relative overflow-hidden py-24 min-h-[92vh] flex items-center
  bg-gradient-to-br from-sky-900 via-sky-800 to-cyan-900
  dark:bg-gradient-to-br dark:from-[#020b18] dark:via-[#020b18] dark:to-[#071527]">

  <!-- Glow orbs -->
  <div class="pointer-events-none absolute top-[-120px] left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full"
    style="background: radial-gradient(circle, rgba(14,165,233,0.20) 0%, rgba(6,182,212,0.08) 50%, transparent 70%);">
  </div>
  <div class="pointer-events-none absolute bottom-0 left-[-100px] w-[400px] h-[400px] rounded-full"
    style="background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%);">
  </div>
  <div class="pointer-events-none absolute top-1/3 right-[-80px] w-[350px] h-[350px] rounded-full"
    style="background: radial-gradient(circle, rgba(6,182,212,0.14) 0%, transparent 70%);">
  </div>

  <!-- Grid lines -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.07]"
    style="background-image: linear-gradient(rgba(14,165,233,1) 1px, transparent 1px), linear-gradient(90deg, rgba(14,165,233,1) 1px, transparent 1px); background-size: 60px 60px;">
  </div>
  <div class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.35) 100%);">
  </div>

  <!-- Floating particles -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
  </div>

  <div class="container mx-auto px-6 xl:px-20 relative z-10">
    <div class="max-w-3xl mx-auto text-center">

      <!-- Badge -->
      <div class="reveal reveal-up inline-flex items-center gap-2 bg-white/10 border border-white/20 text-sky-200 text-xs font-semibold px-4 py-1.5 rounded-full mb-6 uppercase tracking-widest backdrop-blur-sm">
        <span class="w-2 h-2 bg-sky-300 rounded-full animate-pulse"></span>
        Facturación electrónica en Ecuador
      </div>

      <!-- Headline -->
      <h1 class="reveal reveal-up reveal-delay-1 font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-tight mb-6">
        Emite tus facturas<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-300 via-cyan-200 to-sky-300 animate-gradient">
          fácil y rápido
        </span>
      </h1>

      <!-- Subtext -->
      <p class="reveal reveal-up reveal-delay-2 text-sky-200/80 text-lg lg:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
        FACEC te permite emitir todos tus comprobantes electrónicos autorizados por el SRI desde cualquier parte del mundo.
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-up reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center mb-14">
        <a
          href="https://app.facec.ec/login"
          aria-label="Ir al inicio de sesión de la aplicación FACEC"
          target="_blank"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-sky-400 hover:bg-sky-300 text-sky-950 font-bold px-10 py-4 text-lg shadow-lg shadow-sky-500/30 btn-hover transition-all"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Iniciar sesión
        </a>
        <a
          href="#precios"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-white/10 hover:bg-white/20 text-white font-semibold px-10 py-4 text-lg border border-white/20 backdrop-blur-sm btn-hover transition-all"
        >
          Ver planes
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>

      <!-- Feature pills -->
      <div class="reveal reveal-up reveal-delay-4 grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-2xl mx-auto mb-12">
        {features.map(f => (
          <div class="flex items-center gap-3 bg-white/8 border border-white/15 backdrop-blur-sm rounded-2xl px-5 py-3 text-left hover:bg-white/15 transition-colors">
            <span class="text-xl flex-shrink-0">{f.icon}</span>
            <span class="text-sky-100 text-sm font-medium">{f.text}</span>
          </div>
        ))}
      </div>

      <!-- Trust -->
      <div class="reveal reveal-up reveal-delay-5 flex flex-wrap justify-center gap-6 text-sm text-sky-300/70 font-medium">
        <span class="flex items-center gap-1.5"><span class="text-emerald-400">✅</span> Autorizado por el SRI</span>
        <span class="flex items-center gap-1.5"><span class="text-sky-300">🔒</span> 100% seguro</span>
        <span class="flex items-center gap-1.5"><span class="text-cyan-300">🚀</span> Sin instalaciones</span>
      </div>

    </div>
  </div>

  <!-- Bottom fade: empalma con la sección siguiente (sky-50 en light, #071527 en dark) -->
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-32
    [background:linear-gradient(to_bottom,transparent,theme(colors.sky.50))]
    dark:[background:linear-gradient(to_bottom,transparent,#071527)]">
  </div>
</section>

<style>
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient {
    background-size: 200% auto;
    animation: gradient-shift 4s ease infinite;
  }

  .particle {
    position: absolute;
    border-radius: 9999px;
    background: rgba(14, 165, 233, 0.6);
    animation: float linear infinite;
  }
  .particle-1 { width: 3px; height: 3px; left: 15%; top: 20%; animation-duration: 8s; animation-delay: 0s; }
  .particle-2 { width: 2px; height: 2px; left: 75%; top: 35%; animation-duration: 12s; animation-delay: 2s; background: rgba(6,182,212,0.7); }
  .particle-3 { width: 4px; height: 4px; left: 55%; top: 70%; animation-duration: 10s; animation-delay: 4s; }
  .particle-4 { width: 2px; height: 2px; left: 30%; top: 60%; animation-duration: 14s; animation-delay: 1s; background: rgba(99,102,241,0.8); }
  .particle-5 { width: 3px; height: 3px; left: 85%; top: 15%; animation-duration: 9s; animation-delay: 3s; background: rgba(6,182,212,0.6); }

  @keyframes float {
    0%   { transform: translateY(0px) translateX(0px); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { transform: translateY(-120px) translateX(30px); opacity: 0; }
  }
</style>
