<section class="relative bg-gradient-to-br from-violet-50 via-purple-50 to-rose-50 py-20 overflow-hidden">
    <!-- Decorative blobs -->
    <div
        class="pointer-events-none absolute top-0 right-0 w-80 h-80 bg-violet-200 opacity-20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"
    >
    </div>
    <div
        class="pointer-events-none absolute bottom-0 left-0 w-80 h-80 bg-rose-200 opacity-20 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"
    >
    </div>

    <div class="container mx-auto px-6 relative z-10">
        <!-- Header -->
        <div class="text-center mb-14">
            <span
                class="reveal reveal-up inline-flex items-center gap-2 bg-rose-100 text-rose-600 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wide"
            >
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"
                    ><path
                        fill-rule="evenodd"
                        d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path></svg
                >
                ¿Por qué elegirnos?
            </span>
            <h2 class="reveal reveal-up reveal-delay-1 text-4xl lg:text-5xl font-extrabold text-violet-900 mb-4">
                Tu firma en <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-rose-500"
                    >buenas manos</span
                >
            </h2>
            <p class="reveal reveal-up reveal-delay-2 text-purple-700 text-lg max-w-xl mx-auto">
                Más de cientos de clientes confían en nosotros para obtener su firma electrónica con total seguridad.
            </p>
        </div>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <div
                class="reveal reveal-scale reveal-delay-1 group bg-white rounded-3xl shadow-lg border border-violet-100 card-hover overflow-hidden"
            >
                <div class="h-1.5 bg-gradient-to-r from-violet-500 to-violet-400"></div>
                <div class="p-7 text-center">
                    <div
                        class="mx-auto mb-5 text-3xl w-16 h-16 bg-gradient-to-br from-violet-100 to-violet-200 rounded-2xl flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-300"
                    >
                        ⚡
                    </div>
                    <h3 class="text-lg font-bold mb-2 text-violet-900">Entrega inmediata</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        Recibe tu firma electrónica en minutos, sin complicaciones.
                    </p>
                    <div
                        class="mt-4 inline-block bg-violet-50 text-violet-600 text-xs font-semibold px-3 py-1 rounded-full"
                    >
                        Mismo día
                    </div>
                </div>
            </div>

            <div
                class="reveal reveal-scale reveal-delay-2 group bg-white rounded-3xl shadow-lg border border-rose-100 card-hover overflow-hidden"
            >
                <div class="h-1.5 bg-gradient-to-r from-rose-500 to-pink-400"></div>
                <div class="p-7 text-center">
                    <div
                        class="mx-auto mb-5 text-3xl w-16 h-16 bg-gradient-to-br from-rose-100 to-rose-200 rounded-2xl flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-300"
                    >
                        💬
                    </div>
                    <h3 class="text-lg font-bold mb-2 text-violet-900">Soporte 24/7</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        Asistencia personalizada por WhatsApp cuando lo necesites.
                    </p>
                    <div
                        class="mt-4 inline-block bg-rose-50 text-rose-600 text-xs font-semibold px-3 py-1 rounded-full"
                    >
                        Siempre disponible
                    </div>
                </div>
            </div>

            <div
                class="reveal reveal-scale reveal-delay-3 group bg-white rounded-3xl shadow-lg border border-purple-100 card-hover overflow-hidden"
            >
                <div class="h-1.5 bg-gradient-to-r from-purple-500 to-violet-400"></div>
                <div class="p-7 text-center">
                    <div
                        class="mx-auto mb-5 text-3xl w-16 h-16 bg-gradient-to-br from-purple-100 to-purple-200 rounded-2xl flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-300"
                    >
                        ✅
                    </div>
                    <h3 class="text-lg font-bold mb-2 text-violet-900">Validez nacional</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        Firmas reconocidas por SRI y demás instituciones en todo Ecuador.
                    </p>
                    <div
                        class="mt-4 inline-block bg-purple-50 text-purple-600 text-xs font-semibold px-3 py-1 rounded-full"
                    >
                        SRI · ARCOTEL
                    </div>
                </div>
            </div>

            <div
                class="reveal reveal-scale reveal-delay-4 group bg-white rounded-3xl shadow-lg border border-pink-100 card-hover overflow-hidden"
            >
                <div class="h-1.5 bg-gradient-to-r from-pink-500 to-rose-400"></div>
                <div class="p-7 text-center">
                    <div
                        class="mx-auto mb-5 text-3xl w-16 h-16 bg-gradient-to-br from-pink-100 to-pink-200 rounded-2xl flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-300"
                    >
                        💎
                    </div>
                    <h3 class="text-lg font-bold mb-2 text-violet-900">Precios justos</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        Planes flexibles que se adaptan a tu presupuesto sin sorpresas.
                    </p>
                    <div
                        class="mt-4 inline-block bg-pink-50 text-pink-600 text-xs font-semibold px-3 py-1 rounded-full"
                    >
                        Sin costos ocultos
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats bar -->
        <div class="reveal reveal-up reveal-delay-5 mt-14 grid grid-cols-2 lg:grid-cols-4 gap-4">
            {
                [
                    { value: "+500", label: "Clientes satisfechos", color: "violet" },
                    { value: "100%", label: "Certificado ARCOTEL", color: "rose" },
                    { value: "<5min", label: "Tiempo de validación", color: "purple" },
                    { value: "5★", label: "Calificación promedio", color: "pink" },
                ].map((s) => (
                    <div class={`bg-white rounded-2xl border border-${s.color}-100 shadow-sm px-5 py-4 text-center`}>
                        <p class={`text-3xl font-extrabold text-${s.color}-600`}>{s.value}</p>
                        <p class="text-gray-500 text-xs mt-1">{s.label}</p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
