---
const advantages = [
  { icon: "⚡", title: "Entrega inmediata",  desc: "Recibe tu firma electrónica en minutos, sin complicaciones.", badge: "Mismo día",        color: "indigo" },
  { icon: "💬", title: "Soporte 24/7",       desc: "Asistencia personalizada por WhatsApp cuando lo necesites.", badge: "Siempre disponible", color: "sky"    },
  { icon: "✅", title: "Validez nacional",   desc: "Firmas reconocidas por SRI y demás instituciones en todo Ecuador.", badge: "SRI · ARCOTEL",  color: "teal"   },
  { icon: "💎", title: "Precios justos",     desc: "Planes flexibles que se adaptan a tu presupuesto sin sorpresas.", badge: "Sin costos ocultos", color: "amber" },
];

const stats = [
  { value: "+500", label: "Clientes satisfechos", color: "indigo" },
  { value: "100%", label: "Certificado ARCOTEL",  color: "sky"    },
  { value: "<5min",label: "Tiempo de validación", color: "teal"   },
  { value: "5★",   label: "Calificación promedio",color: "amber"  },
];

const badgeLight: Record<string, string> = {
  indigo: "bg-indigo-100 text-indigo-700 border-indigo-200",
  sky:    "bg-sky-100 text-sky-700 border-sky-200",
  teal:   "bg-teal-100 text-teal-700 border-teal-200",
  amber:  "bg-amber-100 text-amber-700 border-amber-200",
};
const badgeDark: Record<string, string> = {
  indigo: "dark:bg-indigo-500/10 dark:text-indigo-400 dark:border-indigo-500/30",
  sky:    "dark:bg-sky-500/10 dark:text-sky-400 dark:border-sky-500/30",
  teal:   "dark:bg-teal-500/10 dark:text-teal-400 dark:border-teal-500/30",
  amber:  "dark:bg-amber-500/10 dark:text-amber-400 dark:border-amber-500/30",
};
const statValueLight: Record<string, string> = {
  indigo: "text-indigo-600",
  sky:    "text-sky-600",
  teal:   "text-teal-600",
  amber:  "text-amber-600",
};
const statValueDark: Record<string, string> = {
  indigo: "dark:text-indigo-400",
  sky:    "dark:text-sky-400",
  teal:   "dark:text-teal-400",
  amber:  "dark:text-amber-400",
};
---

<section class="relative bg-indigo-50/50 dark:bg-[#071527] py-20 overflow-hidden">

  <!-- Blob / glow -->
  <div class="pointer-events-none absolute bottom-0 right-0 w-[500px] h-[500px] rounded-full"
    style="background: radial-gradient(circle, rgba(14,165,233,0.06) 0%, transparent 70%);">
  </div>

  <div class="container mx-auto px-6 relative z-10">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="reveal reveal-up inline-flex items-center gap-2 bg-sky-100 dark:bg-sky-500/10 border border-sky-200 dark:border-sky-500/20 text-sky-700 dark:text-sky-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-widest">
        ¿Por qué elegirnos?
      </span>
      <h2 class="reveal reveal-up reveal-delay-1 text-4xl lg:text-5xl font-extrabold text-indigo-900 dark:text-white mb-4">
        Tu firma en
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-sky-400 dark:from-indigo-400 dark:to-sky-300"> buenas manos</span>
      </h2>
      <p class="reveal reveal-up reveal-delay-2 text-indigo-700 dark:text-slate-400 text-lg max-w-xl mx-auto">
        Cientos de clientes confían en nosotros para obtener su firma electrónica con total seguridad.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {advantages.map((a, i) => (
        <div class={`reveal reveal-scale reveal-delay-${i + 1} group bg-white dark:bg-white/5 border border-indigo-100 dark:border-white/10 rounded-3xl p-7 text-center hover:border-indigo-200 dark:hover:border-white/20 shadow-sm dark:shadow-none transition-all`}>
          <div class="mx-auto mb-5 text-3xl w-16 h-16 bg-indigo-50 dark:bg-white/5 border border-indigo-100 dark:border-white/10 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            {a.icon}
          </div>
          <h3 class="text-lg font-bold mb-2 text-indigo-900 dark:text-white">{a.title}</h3>
          <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-4">{a.desc}</p>
          <span class={`inline-block text-xs font-semibold px-3 py-1 rounded-full border ${badgeLight[a.color]} ${badgeDark[a.color]}`}>
            {a.badge}
          </span>
        </div>
      ))}
    </div>

    <!-- Stats bar -->
    <div class="reveal reveal-up reveal-delay-5 grid grid-cols-2 lg:grid-cols-4 gap-4">
      {stats.map((s) => (
        <div class="bg-white dark:bg-white/5 border border-indigo-100 dark:border-white/10 rounded-2xl px-5 py-4 text-center shadow-sm dark:shadow-none">
          <p class={`text-3xl font-extrabold ${statValueLight[s.color]} ${statValueDark[s.color]}`}>{s.value}</p>
          <p class="text-slate-500 dark:text-slate-500 text-xs mt-1">{s.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
