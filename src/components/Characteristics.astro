---
const features = [
  {
    icon: "✅",
    title: "Adaptable a cualquier negocio",
    desc: "Configura FACEC según el giro de tu negocio, sin importar el sector.",
    accent: "from-sky-400 to-sky-300",
    tag: "Flexibilidad",
    tagLight: "bg-sky-50 text-sky-600",
    tagDark: "dark:bg-sky-500/10 dark:text-sky-400",
    iconBg: "bg-sky-100 dark:bg-sky-500/10",
    border: "border-sky-100 dark:border-white/10",
  },
  {
    icon: "📧",
    title: "Envío automático por correo",
    desc: "Tus clientes reciben sus comprobantes al instante en su bandeja de entrada.",
    accent: "from-cyan-400 to-cyan-300",
    tag: "Automatización",
    tagLight: "bg-cyan-50 text-cyan-600",
    tagDark: "dark:bg-cyan-500/10 dark:text-cyan-400",
    iconBg: "bg-cyan-100 dark:bg-cyan-500/10",
    border: "border-cyan-100 dark:border-white/10",
  },
  {
    icon: "🏢",
    title: "Multi-establecimientos",
    desc: "Gestiona múltiples sucursales y puntos de emisión desde un solo panel.",
    accent: "from-indigo-400 to-indigo-300",
    tag: "Multiempresa",
    tagLight: "bg-indigo-50 text-indigo-600",
    tagDark: "dark:bg-indigo-500/10 dark:text-indigo-400",
    iconBg: "bg-indigo-100 dark:bg-indigo-500/10",
    border: "border-indigo-100 dark:border-white/10",
  },
  {
    icon: "🧠",
    title: "Interfaz intuitiva",
    desc: "Diseño fácil de usar para que factures sin necesidad de capacitación.",
    accent: "from-violet-400 to-violet-300",
    tag: "Fácil de usar",
    tagLight: "bg-violet-50 text-violet-600",
    tagDark: "dark:bg-violet-500/10 dark:text-violet-400",
    iconBg: "bg-violet-100 dark:bg-violet-500/10",
    border: "border-violet-100 dark:border-white/10",
  },
  {
    icon: "🔄",
    title: "Actualizaciones automáticas",
    desc: "Siempre tendrás la versión más reciente, sin costo adicional.",
    accent: "from-emerald-400 to-emerald-300",
    tag: "Gratuitas",
    tagLight: "bg-emerald-50 text-emerald-600",
    tagDark: "dark:bg-emerald-500/10 dark:text-emerald-400",
    iconBg: "bg-emerald-100 dark:bg-emerald-500/10",
    border: "border-emerald-100 dark:border-white/10",
  },
  {
    icon: "📈",
    title: "Escalable contigo",
    desc: "Crece sin límites: cambia de plan cuando tu negocio lo requiera.",
    accent: "from-amber-400 to-amber-300",
    tag: "Sin límites",
    tagLight: "bg-amber-50 text-amber-600",
    tagDark: "dark:bg-amber-500/10 dark:text-amber-400",
    iconBg: "bg-amber-100 dark:bg-amber-500/10",
    border: "border-amber-100 dark:border-white/10",
  },
  {
    icon: "📊",
    title: "Reportes en Excel y PDF",
    desc: "Exporta tus comprobantes y resúmenes en los formatos que necesitas.",
    accent: "from-rose-400 to-rose-300",
    tag: "Exportación",
    tagLight: "bg-rose-50 text-rose-600",
    tagDark: "dark:bg-rose-500/10 dark:text-rose-400",
    iconBg: "bg-rose-100 dark:bg-rose-500/10",
    border: "border-rose-100 dark:border-white/10",
  },
  {
    icon: "📱",
    title: "Compatible con todo dispositivo",
    desc: "Accede desde tu computadora, tablet o celular sin instalar nada.",
    accent: "from-teal-400 to-teal-300",
    tag: "Multiplataforma",
    tagLight: "bg-teal-50 text-teal-600",
    tagDark: "dark:bg-teal-500/10 dark:text-teal-400",
    iconBg: "bg-teal-100 dark:bg-teal-500/10",
    border: "border-teal-100 dark:border-white/10",
  },
];
---

<section id="caracteristicas" class="relative bg-white dark:bg-[#020b18] py-20 overflow-hidden">

  <!-- Blobs light / glow dark -->
  <div class="pointer-events-none absolute -top-20 -left-20 w-80 h-80 bg-sky-200 dark:bg-sky-500 opacity-20 dark:opacity-5 rounded-full blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-20 -right-20 w-80 h-80 bg-cyan-200 dark:bg-cyan-500 opacity-20 dark:opacity-5 rounded-full blur-3xl"></div>

  <div class="container mx-auto px-6 relative z-10">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="reveal reveal-up inline-flex items-center gap-2 bg-sky-100 dark:bg-sky-500/10 border border-sky-200 dark:border-sky-500/20 text-sky-700 dark:text-sky-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wide">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>
        Funcionalidades
      </span>
      <h2 class="reveal reveal-up reveal-delay-1 text-4xl lg:text-5xl font-extrabold text-sky-900 dark:text-white mb-4">
        Características que hacen<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-cyan-500">única a FACEC</span>
      </h2>
      <p class="reveal reveal-up reveal-delay-2 text-sky-700 dark:text-slate-400 text-lg max-w-xl mx-auto">
        Una aplicación <span class="font-semibold">100% en la nube</span>. Solo necesitas conexión a Internet para acceder desde cualquier lugar y dispositivo.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((f, i) => (
        <div class={`reveal reveal-up reveal-delay-${(i % 4) + 1} group bg-white dark:bg-white/5 rounded-3xl border ${f.border} shadow-md dark:shadow-none card-hover overflow-hidden relative flex flex-col`}>
          <div class={`h-1.5 bg-gradient-to-r ${f.accent} flex-shrink-0`}></div>

          <div class="p-6 flex flex-col flex-1">
            <div class={`w-14 h-14 ${f.iconBg} rounded-2xl flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform duration-300 shadow-sm dark:shadow-none`}>
              {f.icon}
            </div>

            <span class={`inline-block self-start text-xs font-semibold px-2.5 py-1 rounded-full mb-3 ${f.tagLight} ${f.tagDark}`}>
              {f.tag}
            </span>

            <h3 class="text-sky-900 dark:text-white font-bold text-base mb-2 leading-snug">{f.title}</h3>
            <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed flex-1">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="reveal reveal-up reveal-delay-4 mt-14 bg-gradient-to-r from-sky-600 to-cyan-500 rounded-3xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-6 text-white shadow-xl shadow-sky-200/50 dark:shadow-sky-900/30">
      <div>
        <h3 class="text-2xl font-extrabold mb-1">¿Listo para empezar?</h3>
        <p class="text-sky-100 text-sm">Únete a cientos de negocios que ya facturan con FACEC.</p>
      </div>
      <a
        href="https://app.facec.ec/login"
        target="_blank"
        class="flex-shrink-0 inline-flex items-center gap-2 bg-white text-sky-700 font-bold px-8 py-3 rounded-full shadow-md hover:bg-sky-50 btn-hover transition-all"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Iniciar sesión
      </a>
    </div>

  </div>
</section>
